{
  "distributions": {
    "saas": {
      "required": ["aero-platform"],
      "forbidden": [],
      "user_model": "LandlordUser",
      "tenancy": true,
      "description": "Multi-tenant SaaS mode with subdomain-based tenant isolation"
    },
    "standalone": {
      "required": ["aero-core"],
      "forbidden": ["aero-platform"],
      "user_model": "User",
      "tenancy": false,
      "description": "Single-tenant standalone installation without platform features"
    }
  },
  "packages": {
    "aero-core": {
      "description": "Foundation for all Aero modules - Auth, Users, Roles, Permissions, Module System",
      "type": "required",
      "dependencies": []
    },
    "aero-platform": {
      "description": "SaaS platform features - Tenancy, Billing, Subscriptions",
      "type": "saas-only",
      "dependencies": ["aero-core"]
    },
    "aero-hrm": {
      "description": "Human Resource Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-crm": {
      "description": "Customer Relationship Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-finance": {
      "description": "Finance & Accounting module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-project": {
      "description": "Project Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-ims": {
      "description": "Inventory Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-pos": {
      "description": "Point of Sale module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-scm": {
      "description": "Supply Chain Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-quality": {
      "description": "Quality Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-dms": {
      "description": "Document Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    },
    "aero-compliance": {
      "description": "Compliance Management module",
      "type": "module",
      "dependencies": ["aero-core"]
    }
  }
}
