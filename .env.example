APP_NAME=DBEDC_ERP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Dhaka
APP_URL=https://platform.com
APP_VERSION=1.2.0

# Multi-tenancy Domain Configuration
# -----------------------------------
# APP_DOMAIN: Your main application domain (e.g., platform.com)
# CENTRAL_DOMAIN: Central platform domain for registration/landing (same as APP_DOMAIN usually)
# ADMIN_DOMAIN: Admin panel subdomain (e.g., admin.platform.com)
#
# For production, set these to your actual domain:
#   APP_DOMAIN=platform.com
#   CENTRAL_DOMAIN=platform.com
#   ADMIN_DOMAIN=admin.platform.com
#
# For local development:
#   APP_DOMAIN=platform.test (or localhost)
#   CENTRAL_DOMAIN=platform.test (or localhost)
#   ADMIN_DOMAIN=admin.platform.test (or admin.localhost)
APP_DOMAIN=platform.com
CENTRAL_DOMAIN=platform.com
ADMIN_DOMAIN=admin.platform.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=platform_central
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration for Multi-Tenancy
# ----------------------------------------
# IMPORTANT: SESSION_DOMAIN must be set to .platform.com (with leading dot)
# This allows session cookies to be shared across all subdomains:
#   - platform.com (main landing)
#   - admin.platform.com (admin panel)
#   - {tenant}.platform.com (tenant apps)
#
# The leading dot is critical for subdomain cookie sharing!
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.platform.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=emam@dhakabypass.com
MAIL_PASSWORD=jarvisMJ@321
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=emam@dhakabypass.com

MAIL_MAILER=log
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

