{
    "name": "aero/analytics",
    "description": "Aero Analytics Module - Business Intelligence and Analytics Platform",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "analytics",
        "business-intelligence",
        "bi",
        "dashboards",
        "reporting",
        "data-warehouse",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Analytics\\": "src/",
            "Aero\\Analytics\\Database\\Factories\\": "database/factories/",
            "Aero\\Analytics\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Analytics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Analytics\\Providers\\AnalyticsModuleProvider"
            ]
        },
        "aero": {
            "package": "analytics",
            "version": "1.0.0",
            "category": "business",
            "description": "Business Intelligence platform with executive dashboards, advanced reporting, data warehouse, and predictive analytics"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}