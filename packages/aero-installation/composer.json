{
    "name": "aero/installation",
    "description": "Aero Installation Package - Unified installation wizard for both SaaS and standalone modes",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "installation",
        "laravel",
        "saas",
        "standalone"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/boost": "*",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Installation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Installation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Installation\\Providers\\AeroInstallationServiceProvider"
            ]
        },
        "aero": {
            "package": "installation",
            "version": "1.0.0",
            "category": "foundation",
            "description": "Installation wizard for SaaS and standalone modes"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
