{
    "name": "aero/finance",
    "description": "Aero Finance Module - Financial Management System",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "finance",
        "accounting",
        "general-ledger",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Finance\\": "src/",
            "Aero\\Finance\\Database\\Factories\\": "database/factories/",
            "Aero\\Finance\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Finance\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Finance\\Providers\\FinanceModuleProvider"
            ]
        },
        "aero": {
            "package": "finance",
            "version": "1.0.0",
            "category": "business",
            "description": "Financial management system with chart of accounts, general ledger, AP/AR, and journal entries"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
