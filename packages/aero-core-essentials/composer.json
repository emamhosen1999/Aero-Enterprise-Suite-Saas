{
    "name": "aero-modules/core-essentials",
    "description": "Core shared components for Aero Enterprise Suite modules - Authentication, roles, and module access control",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "aero-enterprise",
        "core",
        "authentication",
        "roles",
        "permissions",
        "multi-tenant",
        "laravel"
    ],
    "authors": [
        {
            "name": "Aero Development Team",
            "email": "dev@aero-enterprise.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "stancl/tenancy": "^4.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "AeroModules\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AeroModules\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AeroModules\\Core\\CoreServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
