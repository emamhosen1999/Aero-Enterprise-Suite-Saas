{
  "name": "aero-crm",
  "short_name": "crm",
  "version": "1.0.0",
  "description": "Aero Customer Relationship Management Module",
  "namespace": "Aero\\Crm",
  "providers": [
    "Aero\\Crm\\AeroCrmServiceProvider"
  ],
  "middleware": [
    "web",
    "auth"
  ],
  "dependencies": {
    "aero-core": "^1.0"
  },
  "routes": {
    "tenant": "routes/tenant.php",
    "web": "routes/web.php",
    "api": "routes/api.php"
  },
  "migrations": {
    "path": "database/migrations"
  },
  "assets": {
    "js": "dist/aero-crm.js",
    "css": "dist/aero-crm.css"
  },
  "pages": {
    "Leads": {
      "Index": "Pages/Leads/Index",
      "Create": "Pages/Leads/Create",
      "Edit": "Pages/Leads/Edit"
    },
    "Contacts": {
      "Index": "Pages/Contacts/Index",
      "Create": "Pages/Contacts/Create"
    },
    "Deals": {
      "Index": "Pages/Deals/Index",
      "Pipeline": "Pages/Deals/Pipeline"
    }
  },
  "permissions": [
    "crm.leads.view",
    "crm.leads.create",
    "crm.leads.edit",
    "crm.leads.delete",
    "crm.contacts.view",
    "crm.contacts.manage",
    "crm.deals.view",
    "crm.deals.manage"
  ],
  "config": {
    "enabled": true,
    "auto_register": true,
    "priority": 20
  }
}
