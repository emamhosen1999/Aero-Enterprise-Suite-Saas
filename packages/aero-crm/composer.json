{
    "name": "aero/crm",
    "description": "Aero CRM Module - Customer Relationship Management",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "crm",
        "customer-relationship-management",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Crm\\": "src/",
            "Aero\\Crm\\Database\\Factories\\": "database/factories/",
            "Aero\\Crm\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Crm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Crm\\Providers\\CrmModuleProvider"
            ]
        },
        "aero": {
            "package": "crm",
            "version": "1.0.0",
            "category": "business",
            "description": "Customer Relationship Management module with deals, opportunities, pipelines, and customer management"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
