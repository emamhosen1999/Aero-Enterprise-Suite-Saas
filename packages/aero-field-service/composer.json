{
    "name": "aero/field-service",
    "description": "Aero Field Service Module - Field Service Management System",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "field-service",
        "fsm",
        "work-orders",
        "technicians",
        "scheduling",
        "mobile",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\FieldService\\": "src/",
            "Aero\\FieldService\\Database\\Factories\\": "database/factories/",
            "Aero\\FieldService\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\FieldService\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\FieldService\\Providers\\FieldServiceModuleProvider"
            ]
        },
        "aero": {
            "package": "field-service",
            "version": "1.0.0",
            "category": "business",
            "description": "Field service management with work order dispatch, mobile apps, technician management, and service agreements"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}