{
  "name": "aero-hrm",
  "short_name": "hrm",
  "version": "1.0.0",
  "description": "Aero Human Resource Management Module",
  "namespace": "Aero\\Hrm",
  "providers": [
    "Aero\\Hrm\\AeroHrmServiceProvider"
  ],
  "middleware": [
    "web",
    "auth"
  ],
  "dependencies": {
    "aero-core": "^1.0"
  },
  "routes": {
    "tenant": "routes/tenant.php",
    "web": "routes/web.php",
    "api": "routes/api.php"
  },
  "migrations": {
    "path": "database/migrations"
  },
  "assets": {
    "js": "dist/aero-hrm.umd.js",
    "css": "dist/aero-hrm.css"
  },
  "pages": {
    "Employees": {
      "Index": "Pages/Employees/Index",
      "Create": "Pages/Employees/Create",
      "Edit": "Pages/Employees/Edit"
    },
    "Attendance": {
      "Index": "Pages/Attendance/Index",
      "Report": "Pages/Attendance/Report"
    },
    "Leave": {
      "Index": "Pages/Leave/Index",
      "Request": "Pages/Leave/Request"
    },
    "Payroll": {
      "Index": "Pages/Payroll/Index",
      "Process": "Pages/Payroll/Process"
    }
  },
  "permissions": [
    "hrm.employees.view",
    "hrm.employees.create",
    "hrm.employees.edit",
    "hrm.employees.delete",
    "hrm.attendance.view",
    "hrm.attendance.manage",
    "hrm.leave.view",
    "hrm.leave.approve",
    "hrm.payroll.view",
    "hrm.payroll.process"
  ],
  "config": {
    "enabled": true,
    "auto_register": true,
    "priority": 10
  }
}
