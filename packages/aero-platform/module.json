{
    "name": "aero-platform",
    "short_name": "platform",
    "namespace": "Aero\\Platform",
    "provider": "Aero\\Platform\\AeroPlatformServiceProvider",
    "version": "1.0.0",
    "description": "Aero Platform - Multi-tenancy orchestration, billing, and SaaS administration",
    "category": "landlord",
    "dependencies": {
        "aero-core": "^1.0"
    },
    "routes": {
        "admin": "routes/admin.php",
        "web": "routes/web.php",
        "installation": "routes/installation.php"
    },
    "middleware": [
        "web",
        "landlord"
    ],
    "migrations": {
        "path": "database/migrations"
    },
    "config": {
        "enabled": true,
        "saas_only": true
    }
}
