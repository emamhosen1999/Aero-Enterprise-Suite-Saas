{
    "name": "aero/rfi",
    "description": "Aero RFI (Request for Inspection) Management Module - Daily Works, Objections, Work Locations",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Aero Development Team",
            "email": "dev@aero.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aero/core": "@dev",
        "spatie/laravel-medialibrary": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Rfi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Rfi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Rfi\\AeroRfiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
