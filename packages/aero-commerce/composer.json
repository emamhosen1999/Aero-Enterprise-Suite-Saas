{
    "name": "aero/commerce",
    "description": "Aero Commerce Module - E-commerce Platform with Multi-vendor Support",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "commerce",
        "e-commerce",
        "online-store",
        "marketplace",
        "multi-vendor",
        "shopping-cart",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Commerce\\": "src/",
            "Aero\\Commerce\\Database\\Factories\\": "database/factories/",
            "Aero\\Commerce\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Commerce\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Commerce\\Providers\\CommerceModuleProvider"
            ]
        },
        "aero": {
            "package": "commerce",
            "version": "1.0.0",
            "category": "business",
            "description": "E-commerce platform with product catalog, shopping cart, order management, payment gateway integration, and multi-vendor marketplace support"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}