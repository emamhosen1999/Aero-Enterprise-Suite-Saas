{
    "name": "aero/manufacturing",
    "description": "Aero Manufacturing Module - Manufacturing Execution System (MES)",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "manufacturing",
        "mes",
        "production",
        "work-orders",
        "bom",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Manufacturing\\": "src/",
            "Aero\\Manufacturing\\Database\\Factories\\": "database/factories/",
            "Aero\\Manufacturing\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Manufacturing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Manufacturing\\Providers\\ManufacturingModuleProvider"
            ]
        },
        "aero": {
            "package": "manufacturing",
            "version": "1.0.0",
            "category": "business",
            "description": "Manufacturing Execution System with work orders, BOM, production planning, shop floor control, and quality management"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}