HOST=0.0.0.0
PORT=8000
WORKERS=4

# Model Configuration
MODEL_NAME=aero-assistant-v1
BASE_MODEL=meta-llama/Llama-2-7b-chat-hf
FINETUNED_MODEL_PATH=./models/aero-assistant-v1
DEVICE=cuda
MAX_TOKENS=2048
TEMPERATURE=0.7

# Embeddings Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Database Configuration (for logging)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aero_ai
DB_USER=postgres
DB_PASSWORD=your_password

# Redis (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Security
API_KEY=your-secure-api-key-change-in-production
CORS_ORIGINS=http://localhost:3000,https://aeos365.com,https://admin.aeos365.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/server.log

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Model Loading
LOAD_IN_8BIT=false
LOAD_IN_4BIT=false
USE_FLASH_ATTENTION=false
