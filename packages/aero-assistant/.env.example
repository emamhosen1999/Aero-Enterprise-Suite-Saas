# ============================================================================
# Aero Assistant Module - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# AI Model Configuration
# ----------------------------------------------------------------------------
# Self-hosted AI model API endpoint
ASSISTANT_MODEL_ENDPOINT=https://ai.aeos365.com/api

# Model name/version to use
ASSISTANT_MODEL_NAME=aero-assistant-v1

# Request timeout in seconds
ASSISTANT_MODEL_TIMEOUT=30

# Max tokens for response generation
ASSISTANT_MODEL_MAX_TOKENS=1000

# Temperature for response generation (0.0 to 1.0)
# Lower = more focused, Higher = more creative
ASSISTANT_MODEL_TEMPERATURE=0.7

# ----------------------------------------------------------------------------
# Vector Database Configuration (PostgreSQL + pgvector)
# ----------------------------------------------------------------------------
# Enable vector search for RAG
ASSISTANT_VECTOR_ENABLED=true

# Embedding dimensions (must match model output, typically 1536)
ASSISTANT_VECTOR_DIMENSIONS=1536

# Number of similar documents to retrieve for RAG
ASSISTANT_VECTOR_TOP_K=5

# Similarity threshold (0.0 to 1.0)
# Higher = more strict matching
ASSISTANT_VECTOR_SIMILARITY_THRESHOLD=0.7

# ----------------------------------------------------------------------------
# Knowledge Base Configuration
# ----------------------------------------------------------------------------
# Index documentation files
ASSISTANT_INDEX_DOCS=true

# Index code comments and PHPDoc
ASSISTANT_INDEX_CODE=true

# Dynamically index installed modules
ASSISTANT_DYNAMIC_INDEXING=true

# Chunk size for document splitting (characters)
ASSISTANT_CHUNK_SIZE=1000

# Chunk overlap (characters)
ASSISTANT_CHUNK_OVERLAP=200

# ----------------------------------------------------------------------------
# Chat Interface Configuration
# ----------------------------------------------------------------------------
# Enable floating assistant button
ASSISTANT_FLOATING_BUTTON=true

# Enable dedicated assistant page
ASSISTANT_DEDICATED_PAGE=true

# Show assistant on all pages
ASSISTANT_SHOW_ALL_PAGES=true

# Max conversation history messages to load
ASSISTANT_MAX_HISTORY=50

# ----------------------------------------------------------------------------
# Conversation Configuration
# ----------------------------------------------------------------------------
# Auto-delete conversations after X days (0 = never)
ASSISTANT_AUTO_DELETE_DAYS=0

# ----------------------------------------------------------------------------
# PostgreSQL pgvector Extension Setup
# ----------------------------------------------------------------------------
# To enable pgvector extension, run this SQL command on your database:
# CREATE EXTENSION IF NOT EXISTS vector;
#
# For installation instructions, visit:
# https://github.com/pgvector/pgvector#installation
