{
    "name": "aero/assistant",
    "description": "Aero AI Assistant Module - RAG-based intelligent assistant for user guidance and task automation",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "assistant",
        "ai",
        "rag",
        "chatbot",
        "laravel",
        "module"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "aero/core": "*",
        "guzzlehttp/guzzle": "^7.8",
        "pgvector/pgvector": "^0.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Assistant\\": "src/",
            "Aero\\Assistant\\Database\\Factories\\": "database/factories/",
            "Aero\\Assistant\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Assistant\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Assistant\\Providers\\AssistantModuleProvider"
            ]
        },
        "aero": {
            "package": "assistant",
            "version": "1.0.0",
            "category": "productivity",
            "description": "AI-powered assistant with RAG capabilities for user guidance, task automation, and contextual help"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
