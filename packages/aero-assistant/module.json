{
  "name": "aero-assistant",
  "short_name": "assistant",
  "version": "1.0.0",
  "description": "Aero AI Assistant Module - RAG-based intelligent assistant",
  "namespace": "Aero\\Assistant",
  "providers": [
    "Aero\\Assistant\\Providers\\AssistantModuleProvider"
  ],
  "middleware": [
    "web",
    "auth"
  ],
  "dependencies": {
    "aero-core": "^1.0"
  },
  "routes": {
    "tenant": "routes/tenant.php",
    "web": "routes/web.php",
    "api": "routes/api.php"
  },
  "migrations": {
    "path": "database/migrations"
  },
  "assets": {
    "js": "dist/aero-assistant.js",
    "css": "dist/aero-assistant.css"
  },
  "pages": {
    "Assistant": {
      "Index": "Pages/Assistant/Index"
    }
  },
  "permissions": [
    "assistant.use",
    "assistant.view_history",
    "assistant.perform_actions",
    "assistant.access_all_modules",
    "assistant.admin"
  ],
  "config": {
    "enabled": true,
    "auto_register": true,
    "priority": 100
  }
}
