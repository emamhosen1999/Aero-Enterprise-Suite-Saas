{
    "name": "aero/core",
    "description": "Aero Core Package - Foundation for all Aero modules including User, Auth, Roles, Permissions, Modules, and Multi-tenancy",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "aero",
        "core",
        "laravel",
        "multi-tenancy",
        "authentication",
        "authorization",
        "rbac",
        "module-system"
    ],
    "authors": [
        {
            "name": "Aero Team",
            "email": "support@aerosuite.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "stancl/tenancy": "^3.9",
        "spatie/laravel-permission": "^6.20",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/fortify": "^1.24",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-medialibrary": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Aero\\Core\\": "src/",
            "Aero\\Core\\Database\\Factories\\": "database/factories/",
            "Aero\\Core\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aero\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aero\\Core\\Providers\\AeroCoreServiceProvider"
            ],
            "aliases": {
                "AeroCore": "Aero\\Core\\Facades\\AeroCore"
            }
        },
        "aero": {
            "package": "core",
            "version": "1.0.0",
            "category": "foundation",
            "description": "Foundation package providing User, Auth, Roles, Permissions, Modules, and Multi-tenancy"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
